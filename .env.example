# ExamNight AI — Root Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is already listed in .gitignore.

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Personal access token from https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# (Optional) Override the default inference model
# HUGGINGFACE_REPO_ID=Qwen/Qwen2.5-7B-Instruct

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://...

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# (Optional) How long login tokens stay valid (default: 24 hours)
# JWT_EXPIRE_HOURS=24
